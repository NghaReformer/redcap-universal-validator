          null
        ],
        [
          "a",
          "2"
        ],
        [
          "b",
          null
        ]
      ]
    },
    {
      "name": "lowercased",
      "expr": "[STYPE]='1'",
      "expect": [
        [
          "stype",
          null
        ]
      ]
    },
    {
      "name": "literals_only",
      "expr": "'1'='1'",
      "expect": []
    }
  ]
}
